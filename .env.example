# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Telegram API credentials (from https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here

# Fernet encryption key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_fernet_key_here

# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=123456789

# AI Provider Keys (at least one required)
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# Storage
DB_PATH=data.db
SESSION_PATH=sessions/

# Logging
LOG_LEVEL=INFO

# Telethon user mode (disabled by default — requires phone auth on first run)
USER_MODE_ENABLED=false

# Rate limiting
MAX_REQUESTS_PER_MINUTE=20
MAX_MESSAGES_PER_CHAT_PER_MINUTE=5
