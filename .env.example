# ─── Telegram Bot API ──────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Telegram User Account (Telethon) ─────────────────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
USER_MODE_ENABLED=false        # set to true to enable user-account automation
SESSION_PATH=sessions/

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_32byte_base64_key_here

# ─── Admin Access ─────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs with full system access
ADMIN_IDS=111111111,222222222

# ─── AI Providers (system-level defaults, users can set their own) ─────────────
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# ─── Storage ──────────────────────────────────────────────────────────────────
DB_PATH=data.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Rate Limits ──────────────────────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=20
MAX_MESSAGES_PER_CHAT_PER_MINUTE=5
